		<AgentServerPath>C:\\Users\\VSRO-Host\\Desktop\\VSRO Server\\Server\\Server\\DSRO-MAIN\\DSRO-MAIN\\AgentServer.exe</AgentServerPath>
	</Patching>

	<Cert>
		<CompileCertPath>C:\\Users\\VSRO-Host\\Desktop\\VSRO Server\\Server\\Server\\CertModule\\CertModule\\1 - compile.bat</CompileCertPath>
	</Cert>
	<ServerCfgPath>C:\\Users\\VSRO-Host\\Desktop\\VSRO Server\\Server\\Server\\DSRO-MAIN\\DSRO-MAIN\\server.cfg</ServerCfgPath>
	<DebugMode>true</DebugMode>

