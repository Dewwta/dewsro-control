<?xml version="1.0" encoding="utf-8" ?>
<ApiSettings>

	<Network>
		<IP>0.0.0.0</IP>
		<Port>5085</Port>
	</Network>

	<Logs>
		<SaveTimerInHours>12</SaveTimerInHours>
		<CleanupTimerInHours>24</CleanupTimerInHours>
	</Logs>

	<Backup>
		<BackupPath>C:\\Users\\Public\\Documents\\DSRO_BACKUPS</BackupPath>
